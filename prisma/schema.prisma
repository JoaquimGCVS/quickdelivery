generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  DELIVERYMAN
}

enum DeliveryStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  DELIVERED
  CANCELLED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  phone     String
  role      UserRole
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  deliveriesAsCustomer    Delivery[] @relation("customer")
  deliveriesAsDeliveryman Delivery[] @relation("deliveryman")

  @@map("users")
}

model Delivery {
  id             String         @id @default(uuid())
  customerId     String         @map("customer_id")
  deliverymanId  String?        @map("deliveryman_id")
  pickupAddress  String         @map("pickup_address")
  dropoffAddress String         @map("dropoff_address")
  description    String
  status         DeliveryStatus @default(PENDING)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  customer    User  @relation("customer", fields: [customerId], references: [id])
  deliveryman User? @relation("deliveryman", fields: [deliverymanId], references: [id])

  @@map("deliveries")
}
