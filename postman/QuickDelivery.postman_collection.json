{
  "info": {
    "name": "QuickDelivery API",
    "description": "Coleção de testes para a API QuickDelivery com autenticação JWT - Sprint 1 Upgrade",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Customer 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"token\", jsonData.token);",
                  "pm.collectionVariables.set(\"customerId\", jsonData.user.id);",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Token exists\", function () {",
                  "    pm.expect(jsonData.token).to.exist;",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer1@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Login Deliveryman 1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"deliverymanToken\", jsonData.token);",
                  "pm.collectionVariables.set(\"deliverymanId\", jsonData.user.id);",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"deliveryman1@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["auth", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Deliveries",
      "item": [
        {
          "name": "List Deliveries (Customer)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/deliveries",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["deliveries"]
            }
          }
        },
        {
          "name": "List Deliveries (Deliveryman - PENDING)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{deliverymanToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/deliveries?status=PENDING",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["deliveries"],
              "query": [
                {
                  "key": "status",
                  "value": "PENDING"
                }
              ]
            }
          }
        },
        {
          "name": "List Deliveries (Deliveryman - All)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{deliverymanToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:3000/deliveries",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["deliveries"]
            }
          }
        },
        {
          "name": "Create Delivery",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"deliveryId\", jsonData.id);",
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"pickupAddress\": \"Rua A, 100 - São Paulo\",\n  \"dropoffAddress\": \"Rua B, 200 - São Paulo\",\n  \"description\": \"Entrega de teste\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/deliveries",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["deliveries"]
            }
          }
        },
        {
          "name": "Accept Delivery (Deliveryman)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{deliverymanToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACCEPTED\",\n  \"deliverymanId\": \"{{deliverymanId}}\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/deliveries/{{deliveryId}}/status",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["deliveries", "{{deliveryId}}", "status"]
            }
          }
        },
        {
          "name": "Update to IN_PROGRESS",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{deliverymanToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/deliveries/{{deliveryId}}/status",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["deliveries", "{{deliveryId}}", "status"]
            }
          }
        },
        {
          "name": "Update to DELIVERED",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{deliverymanToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"DELIVERED\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/deliveries/{{deliveryId}}/status",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["deliveries", "{{deliveryId}}", "status"]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List Customers",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3000/customers",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["customers"]
            }
          }
        },
        {
          "name": "List Deliverymen",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:3000/deliverymen",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["deliverymen"]
            }
          }
        }
      ]
    },
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "http://localhost:3000/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["health"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "customerId",
      "value": ""
    },
    {
      "key": "deliverymanToken",
      "value": ""
    },
    {
      "key": "deliverymanId",
      "value": ""
    },
    {
      "key": "deliveryId",
      "value": ""
    }
  ]
}
